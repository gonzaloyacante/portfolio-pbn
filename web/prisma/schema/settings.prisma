// ============================================
// SETTINGS - NORMALIZED (NO JSON)
// ============================================

/// Home Page Hero and Featured Settings
model HomeSettings {
  id  String @id @default(cuid())
  key String @unique @default("singleton")

  // ===== TÍTULO 1 ("Make-up") =====
  heroTitle1Text      String? @default("Make-up")
  heroTitle1Font      String? // null = hereda --font-brand del Theme
  heroTitle1FontUrl   String?
  heroTitle1FontSize  Int?    @default(112)
  heroTitle1Color     String? // Light mode, null = hereda --primary
  heroTitle1ColorDark String? // Dark mode, null = hereda --primary
  heroTitle1ZIndex    Int?    @default(20)
  heroTitle1OffsetX   Int?    @default(0) // Ajuste horizontal (px)
  heroTitle1OffsetY   Int?    @default(0) // Ajuste vertical (px)
  showHeroTitle1      Boolean @default(true)

  // ===== TÍTULO 2 ("Portfolio") =====
  heroTitle2Text      String? @default("Portfolio")
  heroTitle2Font      String?
  heroTitle2FontUrl   String?
  heroTitle2FontSize  Int?    @default(96)
  heroTitle2Color     String?
  heroTitle2ColorDark String?
  heroTitle2ZIndex    Int?    @default(10)
  heroTitle2OffsetX   Int?    @default(0)
  heroTitle2OffsetY   Int?    @default(0)
  showHeroTitle2      Boolean @default(true)

  // ===== NOMBRE PROPIETARIO ("Paola Bolívar Nievas") =====
  ownerNameText      String? @default("Paola Bolívar Nievas")
  ownerNameFont      String?
  ownerNameFontUrl   String?
  ownerNameFontSize  Int?    @default(36)
  ownerNameColor     String?
  ownerNameColorDark String?
  ownerNameZIndex    Int?    @default(15)
  ownerNameOffsetX   Int?    @default(0)
  ownerNameOffsetY   Int?    @default(0)
  showOwnerName      Boolean @default(true)

  // ===== IMAGEN PRINCIPAL =====
  heroMainImageUrl     String?
  heroMainImageAlt     String? @default("Trabajo destacado")
  heroMainImageCaption String?
  heroImageStyle       String? @default("original") // original, square, circle, landscape, portrait, star
  heroMainImageZIndex  Int?    @default(5)
  heroMainImageOffsetX Int?    @default(0)
  heroMainImageOffsetY Int?    @default(0)

  // ===== ILUSTRACIÓN =====
  illustrationUrl      String?
  illustrationAlt      String? @default("Ilustración maquilladora")
  illustrationZIndex   Int?    @default(10)
  illustrationOpacity  Int?    @default(100)
  illustrationSize     Int?    @default(100)
  illustrationOffsetX  Int?    @default(0)
  illustrationOffsetY  Int?    @default(0)
  illustrationRotation Int?    @default(0) // Grados

  // ===== BOTÓN CTA =====
  ctaText     String? @default("Ver Portfolio")
  ctaLink     String? @default("/portfolio")
  ctaFont     String? // null = hereda font del theme
  ctaFontUrl  String?
  ctaFontSize Int?    @default(16)
  ctaVariant  String? @default("default") // default, secondary, outline, ghost
  ctaSize     String? @default("default") // sm, default, lg (padding/height)
  // ⚠️ NO hay colores individuales - usa Theme global según variant
  ctaOffsetX  Int?    @default(0)
  ctaOffsetY  Int?    @default(0)

  // ===== MOBILE OVERRIDES (responsive) =====
  // Título 1 mobile
  heroTitle1MobileOffsetX    Int? @default(0)
  heroTitle1MobileOffsetY    Int? @default(0)
  heroTitle1MobileFontSize   Int? @default(56)
  // Título 2 mobile
  heroTitle2MobileOffsetX    Int? @default(0)
  heroTitle2MobileOffsetY    Int? @default(0)
  heroTitle2MobileFontSize   Int? @default(72)
  // Owner name mobile
  ownerNameMobileOffsetX     Int? @default(0)
  ownerNameMobileOffsetY     Int? @default(0)
  ownerNameMobileFontSize    Int? @default(28)
  // Hero main image mobile
  heroMainImageMobileOffsetX Int? @default(0)
  heroMainImageMobileOffsetY Int? @default(0)
  // Illustration mobile
  illustrationMobileOffsetX  Int? @default(0)
  illustrationMobileOffsetY  Int? @default(0)
  illustrationMobileSize     Int? @default(60)
  illustrationMobileRotation Int? @default(0)
  // CTA mobile
  ctaMobileOffsetX           Int? @default(0)
  ctaMobileOffsetY           Int? @default(0)
  ctaMobileFontSize          Int? @default(16)

  // ===== SECCIÓN IMÁGENES DESTACADAS =====
  showFeaturedImages     Boolean @default(true)
  featuredTitle          String? @default("Galería Destacada")
  featuredTitleFont      String?
  featuredTitleFontUrl   String?
  featuredTitleFontSize  Int?    @default(32)
  featuredTitleColor     String?
  featuredTitleColorDark String?
  featuredCount          Int     @default(6)

  // Meta
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("home_settings")
}

/// About Page Bio and Profile Settings
model AboutSettings {
  id                String   @id @default(cuid())
  key               String   @unique @default("singleton")
  // Illustration
  illustrationUrl   String?
  illustrationAlt   String?  @default("Ilustración sobre mí")
  /// Cuadrado máximo (px) — escritorio / `sm+`
  illustrationMaxPx        Int? @default(112)
  /// Cuadrado máximo (px) — vista estrecha
  illustrationMobileMaxPx  Int? @default(96)
  // Bio
  bioTitle          String?  @default("Hola, soy Paola.")
  /// Null = hereda fuente script del tema + FontLoader no aplica URL propia
  bioTitleFont       String?
  bioTitleFontUrl    String?
  /// Null = tamaño vía `--font-script-size` del tema
  bioTitleFontSize   Int?
  bioTitleMobileFontSize Int?
  bioTitleColor      String?
  bioTitleColorDark  String?
  bioIntro          String?  @db.Text
  bioDescription    String?  @db.Text
  // Profile Image (oval)
  profileImageUrl   String?
  profileImageAlt   String?  @default("Paola Bolívar Nievas")
  profileImageShape String?  @default("ellipse") // ellipse | rounded | circle | none
  profileImageShadowEnabled  Boolean @default(true)
  profileImageShadowBlur     Int?    @default(24)
  profileImageShadowSpread   Int?    @default(0)
  profileImageShadowOffsetX  Int?    @default(0)
  profileImageShadowOffsetY  Int?    @default(8)
  profileImageShadowColor    String? // #RRGGBB, null = usar --primary
  profileImageShadowOpacity  Int?    @default(35) // 0–100
  // Skills
  skills            String[] @default([])
  yearsExperience   Int?
  // Certifications (for professional credibility)
  certifications    String[] @default([])
  // Meta
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("about_settings")
}

/// Public services listing hero (/servicios) — textos y tipografía del bloque superior
model ServicesPageSettings {
  id    String @id @default(cuid())
  key   String @unique @default("singleton")

  listTitle         String? @default("Mis Servicios")
  listIntro         String? @db.Text
  listTitleFont     String?
  listTitleFontUrl  String?
  listTitleFontSize Int?
  listTitleMobileFontSize Int?
  listTitleColor    String?
  listTitleColorDark String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("services_page_settings")
}

/// Contact Page Settings with Form Labels
model ContactSettings {
  id               String   @id @default(cuid())
  key              String   @unique @default("singleton")
  // Page Title
  pageTitle        String?  @default("Contacto")
  // Illustration
  illustrationUrl  String?
  illustrationAlt  String?  @default("Ilustración contacto")
  ownerName        String?  @default("Paola Bolívar Nievas")
  // Contact Info
  email            String?
  phone            String?
  whatsapp         String?
  instagram        String? // URL del perfil de Instagram
  instagramUsername String? @default("") // @username para mostrar
  showInstagram    Boolean  @default(true)
  // Instagram Post Embed
  instagramPostUrl     String? // URL of specific Instagram post to embed
  showInstagramEmbed   Boolean @default(false)
  location         String?
  // Visibility Toggles
  showSocialLinks  Boolean  @default(true)
  showPhone        Boolean  @default(true)
  showWhatsapp     Boolean  @default(true)
  showEmail        Boolean  @default(true)
  showLocation     Boolean  @default(true)
  // Meta
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("contact_settings")
}

/// Category Display Settings
model CategorySettings {
  id              String   @id @default(cuid())
  key             String   @unique @default("singleton")
  showDescription Boolean  @default(true)
  // Layout
  gridColumns     Int      @default(4)
  // Meta
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("category_settings")
}

/// Testimonial Display Settings (SRP: separate from About)
model TestimonialSettings {
  id          String   @id @default(cuid())
  key         String   @unique @default("singleton")
  showOnAbout Boolean  @default(true)
  title       String?  @default("Lo que dicen mis clientes")
  maxDisplay  Int      @default(6)
  // Meta
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("testimonial_settings")
}

/// Theme Colors and Typography
model ThemeSettings {
  id                  String   @id @default(cuid())
  key                 String   @unique @default("singleton")
  // Light Theme Colors — alineado con web/src/lib/design-tokens.ts (BRAND)
  primaryColor        String   @default("#6c0a0a")
  secondaryColor      String   @default("#fce7f3")
  accentColor         String   @default("#fff1f9")
  backgroundColor     String   @default("#fff8fc")
  textColor           String   @default("#1a050a")
  cardBgColor         String   @default("#ffffff")
  // Dark Theme Colors
  darkPrimaryColor    String   @default("#fb7185")
  darkSecondaryColor  String   @default("#881337")
  darkAccentColor     String   @default("#2a1015")
  darkBackgroundColor String   @default("#0f0505")
  darkTextColor       String   @default("#fafafa")
  darkCardBgColor     String   @default("#1c0a0f")
  // Typography - Base
  headingFont         String   @default("Poppins")
  headingFontUrl      String?
  headingFontSize     Int      @default(32)
  scriptFont          String   @default("Great Vibes")
  scriptFontUrl       String?
  scriptFontSize      Int      @default(24)
  bodyFont            String   @default("Open Sans")
  bodyFontUrl         String?
  bodyFontSize        Int      @default(16)
  // Typography - Brand (Specifics)
  brandFont           String?  @default("Saira Extra Condensed") // "Make-up"
  brandFontUrl        String?
  brandFontSize       Int      @default(112)
  portfolioFont       String?  @default("Saira Extra Condensed") // "Portfolio" text
  portfolioFontUrl    String?
  portfolioFontSize   Int      @default(96)
  signatureFont       String?  @default("Dawning of a New Day") // "Paola Bolivar Nievas"
  signatureFontUrl    String?
  signatureFontSize   Int      @default(36)
  // Layout
  borderRadius        Int      @default(40)
  // Meta
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("theme_settings")
}

/// Social Media Links (Normalized)
model SocialLink {
  id        String   @id @default(cuid())
  platform  String // instagram, tiktok, youtube, whatsapp, linkedin, facebook
  url       String
  username  String?
  icon      String? // lucide-react icon name
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([platform])
  @@index([isActive, sortOrder])
  @@map("social_links")
}

// ============================================
// GLOBAL SETTINGS - Site-wide configuration
// ============================================

/// Site-wide SEO and branding settings
model SiteSettings {
  id  String @id @default(cuid())
  key String @unique @default("singleton")

  // Branding
  siteName    String  @default("Paola Bolívar Nievas - Make-up Artist")
  siteTagline String? @default("Especialista en maquillaje profesional")
  logoUrl     String?
  faviconUrl  String?

  // SEO
  defaultMetaTitle       String? @default("Paola Bolívar Nievas | Make-up Artist Portfolio")
  defaultMetaDescription String? @db.Text
  defaultOgImage         String?

  // Contact
  defaultEmail    String?
  defaultPhone    String?
  defaultWhatsapp String?
  defaultAddress  String? @db.Text

  // Analytics
  googleAnalyticsId  String?
  googleTagManagerId String?

  // Features
  maintenanceMode    Boolean @default(false)
  maintenanceMessage String? @db.Text
  // Page Visibility
  showAboutPage      Boolean @default(true)
  showGalleryPage    Boolean @default(true)
  showServicesPage   Boolean @default(false)
  showContactPage    Boolean @default(true)

  allowIndexing Boolean @default(true) // SEO robots

  // ── Navbar / Encabezado ──────────────────────────────────────────
  navbarBrandText      String?  @default("Paola BN")
  navbarBrandFont      String?  // Font family name, e.g. "Great Vibes"
  navbarBrandFontUrl   String?  // Google Fonts embed URL
  navbarBrandFontSize  Int?     @default(30) // px
  navbarBrandColor     String?  // CSS color light mode
  navbarBrandColorDark String?  // CSS color dark mode
  navbarShowBrand      Boolean  @default(true)

  // Meta
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

/// Email notification settings
model EmailSettings {
  id  String @id @default(cuid())
  key String @unique @default("singleton")

  // Notification toggles
  sendContactNotifications     Boolean @default(true)
  sendBookingNotifications     Boolean @default(true)
  sendTestimonialNotifications Boolean @default(true)

  // Recipients
  notificationEmails String[] @default([])

  // Meta
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("email_settings")
}
