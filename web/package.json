{
  "name": "portfolio-pbn",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "build:analyze": "ANALYZE=true prisma generate && ANALYZE=true next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "clean": "rm -rf .next node_modules",
    "fresh": "pnpm run clean && pnpm install && pnpm exec prisma generate",
    "type-check": "pnpm exec tsc --noEmit -p tsconfig.typecheck.json",
    "check:all": "pnpm run type-check && pnpm run lint",
    "verify": "pnpm run check:all && pnpm run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "openapi:generate": "tsx scripts/generate-openapi.ts",
    "openapi:generate:dart": "openapi-generator-cli generate -i scripts/openapi.json -g dart-dio -o ../../app/packages/portfolio_pbn_api --additional-properties=pubName=portfolio_pbn_api,nullSafe=true,serializationLibrary=json_serializable,disallowAdditionalPropertiesIfNotPresent=false",
    "openapi:all": "pnpm openapi:generate && pnpm openapi:generate:dart",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:ui": "vitest --ui",
    "test:unit:coverage": "vitest run --coverage",
    "validate:env": "pnpm exec tsx scripts/validate-env.ts",
    "audit:migrations": "pnpm exec tsx prisma/audit-schema-migrations.ts",
    "db:migrate": "prisma migrate deploy",
    "pre-commit": "pnpm exec tsx scripts/pre-commit-checks.ts",
    "stress:seed": "pnpm exec tsx scripts/seed-stress-test.ts",
    "stress:clean": "pnpm exec tsx scripts/delete-test-data.ts",
    "db:reset": "prisma db push --force-reset",
    "db:seed": "prisma db seed",
    "db:seed:admin:dev": "pnpm exec tsx scripts/seed-admin-dev.ts",
    "db:seed:admin:prod": "pnpm exec tsx scripts/seed-admin-prod.ts",
    "db:fresh": "pnpm db:reset && pnpm db:seed",
    "db:push": "prisma db push",
    "db:push:prod": "dotenv -e .env.production -- prisma migrate deploy",
    "db:studio": "prisma studio"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "8.5.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@sentry/nextjs": "^10.62.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^26.0.1",
    "@types/nprogress": "^0.2.3",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "dompurify": "3.4.11",
    "framer-motion": "^12.42.0",
    "isomorphic-dompurify": "^3.18.0",
    "jose": "^6.2.3",
    "lodash": "4.18.1",
    "lucide-react": "^0.575.0",
    "maplibre-gl": "^5.24.0",
    "next": "^16.2.9",
    "next-auth": "^4.24.14",
    "next-themes": "^0.4.6",
    "nprogress": "^0.2.0",
    "pg": "^8.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-google-recaptcha-v3": "^1.11.0",
    "react-hook-form": "^7.80.0",
    "react-hot-toast": "^2.6.0",
    "react-international-phone": "^4.8.0",
    "resend": "^6.16.0",
    "swr": "^2.4.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "web-vitals": "^5.3.0",
    "yet-another-react-lightbox": "^3.32.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.9",
    "@openapitools/openapi-generator-cli": "^2.39.0",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "1.0.0",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.1",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prisma": "7.8.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.2",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "d3-color": "^3.1.0",
      "hono@*": "4.12.25",
      "@hono/node-server@*": "1.19.13",
      "minimatch@*": "10.2.3",
      "rollup@*": "4.59.0",
      "serialize-javascript@*": "7.0.5",
      "flatted@*": "3.4.2",
      "effect@*": "3.20.0",
      "nodemailer@*": "8.0.5",
      "brace-expansion@*": "5.0.6",
      "picomatch@*": "4.0.4",
      "yaml@*": "2.8.3",
      "lodash@*": "4.18.1",
      "lodash-es@*": "4.18.1",
      "defu@*": "6.1.5",
      "vite@*": "7.3.5",
      "dompurify@*": "3.4.11",
      "esbuild@*": "0.25.5",
      "postcss@*": "8.5.10",
      "uuid@*": "14.0.0",
      "undici@*": "7.28.0",
      "ws@*": "7.5.11",
      "@opentelemetry/core@*": "2.8.0",
      "js-yaml@*": "4.2.0",
      "@babel/core@*": "7.29.6"
    },
    "onlyBuiltDependencies": [
      "@openapitools/openapi-generator-cli",
      "@prisma/client",
      "@prisma/engines",
      "@sentry/cli",
      "esbuild",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  }
}
