#!/usr/bin/env sh

echo ""
echo "╔══════════════════════════════════════════════════════════════╗"
echo "║      🚀 PORTFOLIO PBN PRE-COMMIT VERIFICATION SUITE         ║"
echo "╚══════════════════════════════════════════════════════════════╝"
echo ""

# Ejecutar desde la raíz del repo (husky corre desde ahí)
# La parte web vive en `web/`. No se hace referencia a un `package.json` en la raíz.
# Si no existe `web/package.json` ni `app/pubspec.yaml` avisamos pero no fallamos.
if [ ! -f "web/package.json" ] && [ ! -f "app/pubspec.yaml" ]; then
  echo "❌ Error: no se encontró web/package.json ni app/pubspec.yaml. No hay checks aplicables."
  exit 1
fi

START_TIME=$(date +%s)

# Detectar herramienta para ejecutar comandos (npx o pnpm exec)
if command -v npx >/dev/null 2>&1; then
  NPX_CMD="npx"
else
  NPX_CMD="pnpm exec"
fi

# No se permiten bypass. Si falla un check, el hook debe fallar.

echo "📋 [1/7] Lint-Staged: Formateando archivos modificados..."
# Ejecutar solo si hay archivos staged relevantes
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
if printf "%s" "$STAGED_FILES" | grep -E '\.(ts|tsx|js|jsx|json|md)$' >/dev/null 2>&1; then
  # Ejecutar lint-staged desde web/ si existe (prettier y plugins están en web/devDependencies)
  if [ -f "web/package.json" ]; then
    if command -v pnpm >/dev/null 2>&1; then
      if ! (cd web && pnpm exec lint-staged); then
        echo "❌ Error en lint-staged (web). Revisa errores de formato/linting en web/."
        exit 1
      fi
    else
      if ! (cd web && npx lint-staged); then
        echo "❌ Error en lint-staged (web). Revisa errores de formato/linting en web/."
        exit 1
      fi
    fi
  else
    echo "❌ Error: hay archivos staged que requieren formateo/linting pero falta web/package.json."
    exit 1
  fi
  echo "✅ Lint-staged completado"
else
  echo "ℹ️  No hay archivos staged relevantes para lint-staged, saltando..."
fi
echo ""

echo "🔍 [2/7] TypeScript: Verificando tipos en 'web' si existe..."
if [ -f "web/tsconfig.json" ]; then
  if ! (cd web && $NPX_CMD tsc --noEmit); then
    echo "❌ Error en type checking dentro de web. Revisa errores de TypeScript en web/."
    exit 1
  fi
  echo "✅ TypeScript type check (web) completado"
else
  echo "ℹ️  web/tsconfig.json no existe, saltando type check para web"
fi
echo ""

echo "🧹 [3/7] ESLint: Verificando código en 'web'..."
if [ -d "web/src" ]; then
  if ! (cd web && $NPX_CMD eslint "src/**/*.{ts,tsx,js,jsx}" --quiet); then
    echo "❌ Error en ESLint (web). Revisa errores en web/src/."
    exit 1
  fi
  echo "✅ ESLint (web) completado sin errores"
else
  echo "ℹ️  web/src no existe, saltando ESLint para web"
fi
echo ""

echo "🗄️  [4/7] Prisma: Validando schema en 'web/prisma' si existe..."
if [ -d "web/prisma" ] || [ -d "web/prisma/schema" ] || [ -f "web/prisma/schema.prisma" ] || [ -f "web/prisma/prisma.config.ts" ]; then
  if ! (cd web && $NPX_CMD prisma validate); then
    echo "❌ Error en Prisma schema (web). Revisa los archivos en web/prisma/."
    exit 1
  fi
  echo "✅ Prisma schema (web) válido"
else
  echo "ℹ️  No se encontró schema de Prisma en web/, saltando..."
fi
echo ""

echo "🏗️  [5/7] Next.js: Verificando build de producción en 'web' (puede ser pesado)..."
if [ -f "web/package.json" ]; then
  if [ "${SKIP_NEXT_BUILD}" = "1" ]; then
    echo "⚡ SKIP_NEXT_BUILD activo: saltando build de Next.js (usar solo si DB no disponible)"
  else
    if ! (cd web && $NPX_CMD next build); then
      echo "❌ Error en build de Next.js (web). El código no compila correctamente."
      exit 1
    fi
    echo "✅ Build de producción (web) exitoso"
  fi
else
  echo "ℹ️  No se encontró web/package.json — no se ejecutan checks de Next.js para web"
fi
echo ""

echo "🔎 [6/7] Comprobaciones extra: scripts y dependencias en web/package.json"
if [ -f "web/package.json" ]; then
  # Verificar que prisma esté en dependencias dev o scripts apunten a web/prisma
  if (grep -q 'prisma' web/package.json); then
    echo "  ✓ Prisma declarado en web/package.json"
  else
    echo "  ⚠️  Prisma no encontrado en web/package.json — verifica que esté correctamente declarado (expected in web)."
  fi
fi
echo ""

echo "📱 [7/7] Flutter/Dart: Formato (auto-fix + re-stage) y análisis en 'app' si existe..."
if [ -f "app/pubspec.yaml" ]; then
  if [ "${SKIP_APP}" = "1" ]; then
    echo "⚡ SKIP_APP activo: saltando checks de app"
  else
    # Preferir dart si está disponible, fallback a flutter
    if command -v dart >/dev/null 2>&1; then
      echo "🔧 Usando 'dart' para formateo y análisis en app/"
      # Auto-format: corrige archivos y los re-stagea automáticamente
      echo "  → Formateando archivos Dart..."
      (cd app && dart format .)
      echo "  → Re-stageando archivos formateados..."
      git add app/
      echo "  → Ejecutando dart analyze..."
      if ! (cd app && dart analyze); then
        echo "❌ Dart analyze encontró problemas en app/."
        exit 1
      fi
    elif command -v flutter >/dev/null 2>&1; then
      echo "🔧 Usando 'flutter' para formateo y análisis en app/"
      # Auto-format: corrige archivos y los re-stagea automáticamente
      echo "  → Formateando archivos Dart..."
      (cd app && flutter format .)
      echo "  → Re-stageando archivos formateados..."
      git add app/
      echo "  → Ejecutando flutter analyze..."
      if ! (cd app && flutter analyze); then
        echo "❌ Flutter analyze encontró problemas en app/."
        exit 1
      fi
    else
      echo "ℹ️  No se encontró 'dart' ni 'flutter' en PATH — saltando checks de app"
    fi
    echo "✅ Checks de app completados"
  fi
else
  echo "ℹ️  No se encontró app/pubspec.yaml, saltando checks para app"
fi
echo ""

echo "⚙️  [7/7] Verificando archivos de configuración principales (web)..."
for config_file in "web/package.json" "web/next.config.ts" "web/tsconfig.json" "web/tailwind.config.ts"; do
  if [ -f "$config_file" ]; then
    echo "  ✓ $config_file"
  else
    echo "  ✗ $config_file faltante (o no aplicable)"
  fi
done

END_TIME=$(date +%s)
DURATION=$((END_TIME - START_TIME))

echo ""
echo "╔══════════════════════════════════════════════════════════════╗"
echo "║     ✅ VERIFICACIONES COMPLETADAS (PARCIALES/CONDICIONALES) ║"
echo "║                   Tiempo total: ${DURATION}s                        ║"
echo "╚══════════════════════════════════════════════════════════════╝"
echo ""
echo "📦 Pre-commit checks ejecutados. Si falló algo, ver mensajes arriba."
